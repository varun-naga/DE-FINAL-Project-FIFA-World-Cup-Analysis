{
  "datasets": [
    {
      "name": "cd7d57ed",
      "displayName": "Year Top Team by Goals",
      "queryLines": [
        "SELECT\n",
        "  *\n",
        "FROM\n",
        "  fifa_worldcup.team_analysis.best_goals_gold"
      ]
    },
    {
      "name": "53d717bc",
      "displayName": "The best tactical teams",
      "queryLines": [
        "SELECT\n",
        "  team_name,\n",
        "  team_code,\n",
        "  total_substitutions,\n",
        "  subs_per_match,\n",
        "  tactical_type\n",
        "FROM\n",
        "  fifa_worldcup.team_analysis.substitutions_gold\n",
        "ORDER BY\n",
        "  total_substitutions DESC\n",
        "LIMIT 10"
      ]
    },
    {
      "name": "yearwise_best_team",
      "displayName": "Year-wise Top Goals Scored Team",
      "queryLines": [
        "SELECT\n",
        "  year,\n",
        "  team_name,\n",
        "  total_goals,\n",
        "  matches_played\n",
        "FROM\n",
        "  fifa_worldcup.team_analysis.year_top_team\n",
        "WHERE\n",
        "  year = :year\n",
        "ORDER BY\n",
        "  year ASC"
      ],
      "parameters": [
        {
          "displayName": "Year",
          "keyword": "year",
          "dataType": "INTEGER",
          "defaultSelection": {
            "values": {
              "dataType": "INTEGER",
              "values": [
                {
                  "value": "2022"
                }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "year_options",
      "displayName": "Year Options",
      "queryLines": [
        "SELECT DISTINCT\n",
        "  year\n",
        "FROM\n",
        "  fifa_worldcup.team_analysis.goals_gold\n",
        "ORDER BY\n",
        "  year ASC"
      ]
    },
    {
      "name": "summary_stats",
      "displayName": "FIFA Summary Stats",
      "queryLines": [
        "SELECT\n",
        "  SUM(g.total_goals) AS total_goals,\n",
        "  COUNT(DISTINCT g.year) AS total_years,\n",
        "  COUNT(DISTINCT g.team_name) AS total_teams,\n",
        "  COUNT(DISTINCT g.team_code) AS total_countries\n",
        "FROM\n",
        "  fifa_worldcup.team_analysis.goals_gold g"
      ]
    },
    {
      "name": "pressure_behavior",
      "displayName": "Pressure Behavior Analysis",
      "queryLines": [
        "WITH top_pressure AS (\n",
        "  SELECT\n",
        "    team_name,\n",
        "    early_fouls,\n",
        "    late_fouls,\n",
        "    aggression_score,\n",
        "    discipline_type,\n",
        "    ROUND(late_fouls * 1.0 / NULLIF(early_fouls, 0), 2) AS pressure_ratio\n",
        "  FROM\n",
        "    fifa_worldcup.team_analysis.bookings_gold\n",
        "  WHERE\n",
        "    early_fouls IS NOT NULL\n",
        "    AND late_fouls IS NOT NULL\n",
        "  ORDER BY\n",
        "    pressure_ratio DESC\n",
        "  LIMIT 10\n",
        ")\n",
        "SELECT\n",
        "  team_name,\n",
        "  'Early Fouls' AS foul_phase,\n",
        "  early_fouls AS foul_count,\n",
        "  pressure_ratio,\n",
        "  discipline_type\n",
        "FROM\n",
        "  top_pressure\n",
        "UNION ALL\n",
        "SELECT\n",
        "  team_name,\n",
        "  'Late Fouls' AS foul_phase,\n",
        "  late_fouls AS foul_count,\n",
        "  pressure_ratio,\n",
        "  discipline_type\n",
        "FROM\n",
        "  top_pressure\n",
        "ORDER BY\n",
        "  pressure_ratio DESC,\n",
        "  foul_phase"
      ]
    },
    {
      "name": "aggressive_disciplined",
      "displayName": "Aggressive vs Disciplined Teams",
      "queryLines": [
        "WITH aggressive AS (\n",
        "  SELECT\n",
        "    team_name,\n",
        "    team_code,\n",
        "    yellow_cards,\n",
        "    red_cards,\n",
        "    total_cards,\n",
        "    cards_per_match,\n",
        "    aggression_score,\n",
        "    discipline_type,\n",
        "    'Aggressive' AS team_behavior\n",
        "  FROM\n",
        "    fifa_worldcup.team_analysis.bookings_gold\n",
        "  ORDER BY\n",
        "    aggression_rank ASC\n",
        "  LIMIT 3\n",
        "),\n",
        "disciplined AS (\n",
        "  SELECT\n",
        "    team_name,\n",
        "    team_code,\n",
        "    yellow_cards,\n",
        "    red_cards,\n",
        "    total_cards,\n",
        "    cards_per_match,\n",
        "    aggression_score,\n",
        "    discipline_type,\n",
        "    'Disciplined' AS team_behavior\n",
        "  FROM\n",
        "    fifa_worldcup.team_analysis.bookings_gold\n",
        "  ORDER BY\n",
        "    discipline_rank ASC\n",
        "  LIMIT 3\n",
        ")\n",
        "SELECT\n",
        "  *\n",
        "FROM\n",
        "  aggressive\n",
        "UNION ALL\n",
        "SELECT\n",
        "  *\n",
        "FROM\n",
        "  disciplined\n",
        "ORDER BY\n",
        "  team_behavior,\n",
        "  cards_per_match DESC"
      ]
    },
    {
      "name": "most_penalty_team",
      "displayName": "Most Penalty Team",
      "queryLines": [
        "SELECT\n",
        "  team_name,\n",
        "  total_penalties AS total_shootout_kicks,\n",
        "  matches_played AS shootout_appearances,\n",
        "  penalties_per_match AS kicks_per_shootout,\n",
        "  penalty_rank\n",
        "FROM\n",
        "  fifa_worldcup.team_analysis.penalty_gold\n",
        "WHERE\n",
        "  matches_played >= 3\n",
        "ORDER BY\n",
        "  total_penalties DESC\n",
        "LIMIT 5"
      ]
    }
  ],
